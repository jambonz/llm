{
  "name": "@jambonz/llm",
  "version": "0.1.0",
  "description": "Voice-oriented LLM adapter library — a uniform interface for streaming chat completions from multiple LLM vendors, with first-class support for tool calls, AbortSignal interruption, and lossless history round-tripping.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./test-kit": {
      "types": "./dist/test-kit/index.d.ts",
      "import": "./dist/test-kit/index.js",
      "require": "./dist/test-kit/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "jambonz",
    "llm",
    "openai",
    "anthropic",
    "google",
    "gemini",
    "vertex",
    "bedrock",
    "streaming",
    "tool-calling",
    "voice-agent"
  ],
  "author": "jambonz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jambonz/llm.git"
  },
  "bugs": {
    "url": "https://github.com/jambonz/llm/issues"
  },
  "homepage": "https://github.com/jambonz/llm#readme",
  "peerDependencies": {
    "vitest": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.0.0",
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^9.17.0",
    "nock": "^13.5.6",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "openai": "^6.34.0"
  }
}
